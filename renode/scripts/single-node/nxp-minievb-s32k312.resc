:name: NXP S32K312
:description: This script runs Zephyr Shell demo on S32K312

using sysbus

include @./Peripherals/NXP/S32K3/MCResetGenerationModule.cs

$name?="NXP S32K312"
mach create $name

machine LoadPlatformDescription @./platforms/boards/nxp-minievb-s32k312.repl
:showAnalyzer lpuart0

$bin?=@../TestApp/baremetal/Debug_FLASH/baremetal.elf

sysbus LoadELF $bin

sysbus.cpu0 VectorTableOffset `sysbus GetSymbolAddress "__Vectors"`

machine StartGdbServer 3333